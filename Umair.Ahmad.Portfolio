<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Umair Ahmad – LLB Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Cormorant+Garamond:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0f2744;
    --navy-mid: #1a3a5c;
    --gold: #b8963e;
    --gold-light: #d4a94e;
    --cream: #f8f5ef;
    --cream-dark: #ede8de;
    --text-dark: #1a1208;
    --text-mid: #4a3f2f;
    --text-muted: #7a6e5e;
    --white: #ffffff;
    --border: rgba(184,150,62,0.25);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'EB Garamond', Georgia, serif;
    background: var(--cream);
    color: var(--text-dark);
    font-size: 17px;
    line-height: 1.75;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--navy);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 3rem; height: 64px;
    border-bottom: 1px solid rgba(184,150,62,0.3);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem; font-weight: 700;
    color: var(--gold-light); letter-spacing: 0.03em;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-family: 'EB Garamond', serif;
    font-size: 0.95rem; letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold-light); }

  /* HERO */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex; align-items: center;
    padding: 6rem 3rem 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 50%; height: 100%;
    background: linear-gradient(135deg, transparent 40%, rgba(184,150,62,0.07) 100%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1100px; margin: 0 auto; width: 100%;
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
  }
  .hero-tag {
    display: inline-block;
    background: rgba(184,150,62,0.18);
    color: var(--gold-light);
    font-size: 0.78rem; letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border: 1px solid rgba(184,150,62,0.35);
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }
  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 300;
    color: var(--gold-light);
    letter-spacing: 0.02em;
    margin-bottom: 1.75rem;
    font-style: italic;
  }
  .hero-desc {
    color: rgba(255,255,255,0.65);
    font-size: 1.05rem; line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 460px;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 0.75rem;
    background: var(--gold);
    color: var(--navy);
    text-decoration: none;
    font-family: 'EB Garamond', serif;
    font-size: 0.95rem; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.85rem 2rem;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s;
  }
  .hero-cta:hover { background: var(--gold-light); transform: translateY(-1px); }
  .hero-image-wrap {
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }
  .hero-image-wrap::before {
    content: '';
    position: absolute;
    width: 320px; height: 380px;
    border: 1px solid rgba(184,150,62,0.4);
    border-radius: 4px;
    top: 16px; left: 16px;
  }
  .hero-img {
    width: 300px; height: 360px;
    object-fit: cover; object-position: center top;
    border-radius: 4px;
    position: relative; z-index: 1;
    border: 1px solid rgba(184,150,62,0.3);
  }
  .hero-img-placeholder {
    width: 300px; height: 360px;
    background: var(--navy-mid);
    border-radius: 4px;
    display: none; align-items: center; justify-content: center;
    position: relative; z-index: 1;
    border: 1px solid rgba(184,150,62,0.3);
  }
  .initials-circle {
    width: 100px; height: 100px;
    border-radius: 50%;
    background: rgba(184,150,62,0.2);
    border: 2px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; font-weight: 700;
    color: var(--gold-light);
  }

  /* SECTIONS COMMON */
  section { padding: 5rem 3rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 0.75rem; letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem; font-weight: 700;
    color: var(--navy);
    line-height: 1.15;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  /* ABOUT */
  #about { background: var(--white); }
  .about-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start;
  }
  .about-text p { color: var(--text-mid); margin-bottom: 1.25rem; font-size: 1.08rem; }
  .about-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  .stat-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.25rem;
    text-align: center;
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 700;
    color: var(--navy);
    display: block;
  }
  .stat-label { font-size: 0.85rem; color: var(--text-muted); letter-spacing: 0.03em; }

  /* COURSES */
  #courses { background: var(--cream); }
  .courses-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;
  }
  .year-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .year-header {
    background: var(--navy);
    padding: 1rem 1.25rem;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .year-badge {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 0.85rem; font-weight: 700;
    color: var(--navy);
    flex-shrink: 0;
  }
  .year-header-text { color: var(--white); font-family: 'Playfair Display', serif; font-size: 1rem; }
  .year-body { padding: 1.25rem; }
  .module-item {
    display: flex; align-items: flex-start; gap: 0.6rem;
    padding: 0.55rem 0;
    border-bottom: 0.5px solid var(--cream-dark);
    font-size: 0.95rem; color: var(--text-mid);
  }
  .module-item:last-child { border-bottom: none; }
  .module-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    margin-top: 0.55rem; flex-shrink: 0;
  }

  /* ACHIEVEMENTS */
  #achievements { background: var(--navy); }
  #achievements .section-title { color: var(--white); border-color: rgba(184,150,62,0.3); }
  .achievements-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .ach-card {
    border: 1px solid rgba(184,150,62,0.3);
    border-radius: 4px;
    padding: 1.75rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .ach-card:hover { border-color: var(--gold); background: rgba(184,150,62,0.05); }
  .ach-icon {
    width: 42px; height: 42px;
    background: rgba(184,150,62,0.15);
    border: 1px solid rgba(184,150,62,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }
  .ach-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; font-weight: 700;
    color: var(--gold-light);
    margin-bottom: 0.5rem;
  }
  .ach-desc { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.65; }

  /* CONTACT */
  #contact { background: var(--white); }
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem;
  }
  .contact-item {
    display: flex; align-items: flex-start; gap: 1rem;
    margin-bottom: 1.75rem;
  }
  .contact-icon-wrap {
    width: 42px; height: 42px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .contact-icon-wrap svg { width: 18px; height: 18px; stroke: var(--gold); fill: none; stroke-width: 1.5; }
  .contact-item-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.2rem; }
  .contact-item-val { font-size: 1rem; color: var(--text-dark); font-weight: 500; }
  .contact-item-val a { color: var(--navy); text-decoration: none; transition: color 0.2s; }
  .contact-item-val a:hover { color: var(--gold); }

  .form-row { margin-bottom: 1.25rem; }
  .form-label {
    display: block;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .form-input, .form-textarea {
    width: 100%;
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: 2px;
    padding: 0.75rem 1rem;
    font-family: 'EB Garamond', serif;
    font-size: 1rem;
    color: var(--text-dark);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus, .form-textarea:focus { border-color: var(--gold); }
  .form-textarea { min-height: 120px; resize: vertical; }
  .form-submit {
    display: inline-block;
    background: var(--navy);
    color: var(--white);
    font-family: 'EB Garamond', serif;
    font-size: 1rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.85rem 2.5rem;
    border: none; border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .form-submit:hover { background: var(--gold); color: var(--navy); transform: translateY(-1px); }

  /* FOOTER */
  footer {
    background: var(--navy);
    border-top: 1px solid rgba(184,150,62,0.25);
    padding: 2rem 3rem;
    text-align: center;
  }
  .footer-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; color: var(--gold-light);
    margin-bottom: 0.4rem;
  }
  .footer-text { font-size: 0.85rem; color: rgba(255,255,255,0.4); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-text > * { animation: fadeUp 0.7s ease both; }
  .hero-tag { animation-delay: 0.1s; }
  .hero-name { animation-delay: 0.2s; }
  .hero-title { animation-delay: 0.3s; }
  .hero-desc { animation-delay: 0.4s; }
  .hero-cta { animation-delay: 0.5s; }
  .hero-image-wrap { animation: fadeUp 0.9s 0.3s ease both; }

  @media (max-width: 768px) {
    nav { padding: 0 1.5rem; }
    .nav-links { gap: 1.25rem; }
    section { padding: 3.5rem 1.5rem; }
    .hero { padding: 6rem 1.5rem 3rem; }
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-image-wrap { order: -1; }
    .hero-img, .hero-img-placeholder { width: 220px; height: 270px; }
    .hero-image-wrap::before { width: 236px; height: 286px; }
    .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .courses-grid { grid-template-columns: 1fr; }
    .achievements-grid { grid-template-columns: 1fr; }
    .about-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Umair Ahmad</div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#courses">Courses</a></li>
    <li><a href="#achievements">Achievements</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-inner">
    <div class="hero-text">
      <span class="hero-tag">LLB &bull; University of London</span>
      <h1 class="hero-name">Umair<br>Ahmad</h1>
      <p class="hero-title">Final Year Law Student</p>
      <p class="hero-desc">A dedicated and intellectually rigorous law student at the University of London, specialising in a broad spectrum of legal disciplines — from constitutional foundations to international and Islamic jurisprudence.</p>
      <a href="#contact" class="hero-cta">Get in Touch &rarr;</a>
    </div>
    <div class="hero-image-wrap">
      <!-- PHOTO: Replace the src below with the path to your photo file -->
      <!-- e.g. src="umair_photo.jpg" if the photo is in the same folder as this file -->
      <img src="umair_photo.jpg" alt="Umair Ahmad" class="hero-img"
           onerror="this.style.display='none'; document.getElementById('placeholder').style.display='flex';">
      <div class="hero-img-placeholder" id="placeholder">
        <div class="initials-circle">UA</div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="section-inner">
    <p class="section-label">Background</p>
    <h2 class="section-title">About Umair</h2>
    <div class="about-grid">
      <div class="about-text">
        <p>Umair Ahmad is a final-year LLB student at the University of London, pursuing a comprehensive legal education that spans both common law traditions and international legal frameworks. His academic journey has equipped him with a deep understanding of the pillars of English law and its broader global dimensions.</p>
        <p>Throughout his studies, Umair has demonstrated a consistent commitment to academic excellence and a genuine curiosity for how law shapes societies. His coursework spans foundational areas such as contract and criminal law, through to advanced disciplines including Islamic law, equity, and the international protection of human rights.</p>
        <p>With strong analytical skills and a passion for justice, Umair aspires to contribute meaningfully to the legal profession — both in practice and in shaping legal discourse.</p>
      </div>
      <div class="about-stats">
        <div class="stat-card">
          <span class="stat-num">3</span>
          <span class="stat-label">Years of Study</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">11</span>
          <span class="stat-label">Modules Completed</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">LLB</span>
          <span class="stat-label">Degree Programme</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">UoL</span>
          <span class="stat-label">University of London</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- COURSES -->
<section id="courses">
  <div class="section-inner">
    <p class="section-label">Academic Record</p>
    <h2 class="section-title">Modules Studied</h2>
    <div class="courses-grid">
      <div class="year-card">
        <div class="year-header">
          <div class="year-badge">1</div>
          <span class="year-header-text">First Year — Foundations</span>
        </div>
        <div class="year-body">
          <div class="module-item"><div class="module-dot"></div>Contract Law</div>
          <div class="module-item"><div class="module-dot"></div>Criminal Law</div>
          <div class="module-item"><div class="module-dot"></div>Legal System &amp; Method</div>
          <div class="module-item"><div class="module-dot"></div>Public Law</div>
        </div>
      </div>
      <div class="year-card">
        <div class="year-header">
          <div class="year-badge">2</div>
          <span class="year-header-text">Second Year — Core Law</span>
        </div>
        <div class="year-body">
          <div class="module-item"><div class="module-dot"></div>Property Law</div>
          <div class="module-item"><div class="module-dot"></div>International Protection of Human Rights</div>
          <div class="module-item"><div class="module-dot"></div>Tort Law</div>
          <div class="module-item"><div class="module-dot"></div>European Union Law</div>
        </div>
      </div>
      <div class="year-card">
        <div class="year-header">
          <div class="year-badge">3</div>
          <span class="year-header-text">Third Year — Advanced</span>
        </div>
        <div class="year-body">
          <div class="module-item"><div class="module-dot"></div>Islamic Law</div>
          <div class="module-item"><div class="module-dot"></div>Equity &amp; Trust</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ACHIEVEMENTS -->
<section id="achievements">
  <div class="section-inner">
    <p class="section-label" style="color: rgba(184,150,62,0.8);">Recognition</p>
    <h2 class="section-title">Achievements &amp; Awards</h2>
    <div class="achievements-grid">
      <div class="ach-card">
        <div class="ach-icon">&#9733;</div>
        <div class="ach-title">Academic Excellence</div>
        <div class="ach-desc">Recognised for outstanding performance and consistent academic achievement across multiple modules throughout the LLB programme.</div>
      </div>
      <div class="ach-card">
        <div class="ach-icon">&#9878;</div>
        <div class="ach-title">Research &amp; Analysis</div>
        <div class="ach-desc">Demonstrated strong legal research and analytical writing skills, with particular depth in human rights, Islamic law, and equity jurisprudence.</div>
      </div>
      <div class="ach-card">
        <div class="ach-icon">&#9876;</div>
        <div class="ach-title">Legal Advocacy</div>
        <div class="ach-desc">Actively engaged in developing oral and written advocacy skills, with a strong foundation in moot preparation and legal argumentation.</div>
      </div>
    </div>
    <p style="color: rgba(255,255,255,0.35); font-size: 0.85rem; margin-top: 2rem; font-style: italic;">* This section will be updated with specific achievements and awards shortly.</p>
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <div class="section-inner">
    <p class="section-label">Get in Touch</p>
    <h2 class="section-title">Contact</h2>
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-icon-wrap">
            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="contact-item-label">Email</div>
            <div class="contact-item-val"><a href="mailto:umairahmad7643@gmail.com">umairahmad7643@gmail.com</a></div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon-wrap">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.77 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.68 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 9.69a16 16 0 006.29 6.29l1.05-1.05a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <div class="contact-item-label">WhatsApp</div>
            <div class="contact-item-val"><a href="https://wa.me/923327520372">0332-7520372</a></div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon-wrap">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="contact-item-label">Availability</div>
            <div class="contact-item-val">Open to opportunities &amp; collaborations</div>
          </div>
        </div>
      </div>
      <div class="contact-form">
        <div class="form-row">
          <label class="form-label">Your Name</label>
          <input type="text" class="form-input" placeholder="e.g. Jane Smith">
        </div>
        <div class="form-row">
          <label class="form-label">Your Email</label>
          <input type="email" class="form-input" placeholder="you@example.com">
        </div>
        <div class="form-row">
          <label class="form-label">Message</label>
          <textarea class="form-textarea" placeholder="Write your message here..."></textarea>
        </div>
        <button class="form-submit" onclick="alert('Thank you for your message! Umair will get back to you shortly.')">Send Message</button>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="footer-name">Umair Ahmad</div>
  <div class="footer-text">LLB Student &bull; University of London &bull; &copy; 2025</div>
</footer>

<script>
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

</body>
</html>
